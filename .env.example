# The startup script sets these defaults for local backend runs when they are unset.
KNOWLEDGE_CURATOR_APP_DATA_DIR=.local/app-data/backend-dev
KNOWLEDGE_CURATOR_SQLITE_PATH=.local/app-data/backend-dev/knowledge-curator.db
KNOWLEDGE_CURATOR_OUTPUT_ROOT=.local/app-data/backend-dev/outputs
KNOWLEDGE_CURATOR_QDRANT_PATH=.local/app-data/backend-dev/qdrant

# The current backend precheck/run flow requires these runtime fields.
KNOWLEDGE_CURATOR_LLM_PROVIDER=stub-llm
KNOWLEDGE_CURATOR_LLM_MODEL=stub-summary-model
KNOWLEDGE_CURATOR_EMBEDDING_PROVIDER=stub-embedding
KNOWLEDGE_CURATOR_EMBEDDING_MODEL=stub-embedding-model

# For remote providers, switch provider names to `openai` or `openai-compatible`.
# `openai-compatible` requires an explicit base URL.
# Examples:
# KNOWLEDGE_CURATOR_LLM_PROVIDER=openai
# KNOWLEDGE_CURATOR_LLM_MODEL=gpt-4.1-mini
# KNOWLEDGE_CURATOR_LLM_BASE_URL=https://api.openai.com/v1
# KNOWLEDGE_CURATOR_LLM_API_KEY=your-llm-api-key
# KNOWLEDGE_CURATOR_EMBEDDING_PROVIDER=openai
# KNOWLEDGE_CURATOR_EMBEDDING_MODEL=text-embedding-3-small
# KNOWLEDGE_CURATOR_EMBEDDING_BASE_URL=https://api.openai.com/v1
# KNOWLEDGE_CURATOR_EMBEDDING_API_KEY=your-embedding-api-key

KNOWLEDGE_CURATOR_LLM_BASE_URL=
KNOWLEDGE_CURATOR_LLM_API_KEY=
KNOWLEDGE_CURATOR_EMBEDDING_BASE_URL=
KNOWLEDGE_CURATOR_EMBEDDING_API_KEY=

KNOWLEDGE_CURATOR_FETCH_CONCURRENCY=3
KNOWLEDGE_CURATOR_LLM_CONCURRENCY=2
KNOWLEDGE_CURATOR_EMBEDDING_CONCURRENCY=2
KNOWLEDGE_CURATOR_FETCH_TIMEOUT_SECONDS=30
KNOWLEDGE_CURATOR_LLM_TIMEOUT_SECONDS=90
KNOWLEDGE_CURATOR_EMBEDDING_TIMEOUT_SECONDS=60
KNOWLEDGE_CURATOR_FETCH_USER_AGENT=KnowledgeCurator/0.1 (+https://localhost)
